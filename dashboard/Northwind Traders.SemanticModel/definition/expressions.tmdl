expression DatabricksGetTable =
		(TableName as text) as table =>
		let
		    Source = Databricks.Catalogs(DatabricksServerHost, DatabricksHttpPath),
		    CatalogRowTry =
		        try Source{[Name=DatabricksCatalog, Kind="Catalog"]}
		        otherwise try Source{[Name=DatabricksCatalog, Kind="Database"]}
		        otherwise try Source{[Name=DatabricksCatalog]}
		        otherwise null,
		    CatalogData = if CatalogRowTry = null then Source else CatalogRowTry[Data],
		    SchemaRowTry =
		        try CatalogData{[Name=DatabricksSchema, Kind="Schema"]}
		        otherwise try CatalogData{[Name=DatabricksSchema, Kind="Database"]}
		        otherwise try CatalogData{[Name=DatabricksSchema]}
		        otherwise null,
		    SchemaData = if SchemaRowTry = null then CatalogData else SchemaRowTry[Data],
		    TableRow =
		        try SchemaData{[Name=TableName, Kind="Table"]}
		        otherwise SchemaData{[Name=TableName]},
		    TableData = TableRow[Data]
		in
		    TableData
	lineageTag: 5c0648ae-51de-4e5f-beff-5306d7852eaa

